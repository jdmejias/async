# Database
DATABASE_URL=postgresql://appuser:password@db:5432/appdb

# RabbitMQ
RABBIT_URL=amqp://guest:guest@rabbit:5672/
EXCHANGE=tasks.exchange
QUEUE=tasks.queue

# Optional SSM parameter names (used when host in URL is localhost/127.0.0.1)
# RABBITMQ_SSM_PARAMETER_NAME=/message-queue/dev/rabbitmq/public_ip
# POSTGRES_SSM_PARAMETER_NAME=/message-queue/dev/postgres/public_ip
